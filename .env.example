# --- ClubSpark / LTA login ---
# For LOGIN_METHOD=lta these are your LTA username (NOT necessarily an email) and
# LTA password. For LOGIN_METHOD=clubspark they are your ClubSpark email/password.
CLUBSPARK_USERNAME=your-lta-username
CLUBSPARK_PASSWORD=your-password
# How to log in:
#   "lta"       -> the LTA login button (accounts migrated to an LTA username)
#   "clubspark" -> the ClubSpark email/password form ("Login with another method")
LOGIN_METHOD=lta

# --- Venue ---
# ClubSpark venue slug; the tool books https://clubspark.lta.org.uk/<VENUE_SLUG>
VENUE_SLUG=ClaphamCommon
BASE_URL=https://clubspark.lta.org.uk

# --- Browser ---
# Visible window by default so you can follow along; set true to run hidden.
HEADLESS=false
# Use your installed Google Chrome (true) or Playwright's bundled Chromium (false).
USE_CHROME=true
# Pause between actions (ms) so the steps are easy to watch.
SLOW_MO_MS=400
SLOT_TIMEOUT_SECONDS=30
# On error, keep the visible window open to inspect the failure (press Enter to
# close, or it auto-closes after KEEP_OPEN_SECONDS). Ignored when HEADLESS=true.
KEEP_OPEN_ON_ERROR=true
KEEP_OPEN_SECONDS=300

# --- Email notifications (optional; leave blank to skip email) ---
# Provider: "smtp" (local dev) or "sendgrid" (recommended on Cloud Run, port 443).
EMAIL_PROVIDER=smtp
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com
# SMTP (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# --- Payment (paid venues) ---
# Card used at checkout. WARNING: storing a full PAN/CVV carries PCI/ToS risk;
# on the cloud these come from Secret Manager, not this file. See deploy/README.md.
CARD_NUMBER=
CARD_EXPIRY=          # MM/YY
CARD_CVV=
CARD_NAME=
CARD_POSTCODE=
# HARD SAFETY GATE. Real bookings cost money. The card is only submitted when
# this is true; otherwise the flow fills the form then stops before paying.
CONFIRM_PAYMENT=false

# --- Google Cloud (cloud only) ---
# When true, secrets above are pulled from Secret Manager before startup.
USE_SECRET_MANAGER=false
GCP_PROJECT=

# --- Scheduled job target (used by tennis-book-job) ---
BOOK_DAYS_AHEAD=7      # book this many days ahead (London time)
# BOOK_DATE=2026-07-28 # optional explicit date, overrides BOOK_DAYS_AHEAD
BOOK_TIME=18:00
BOOK_DURATION=60
BOOK_COURT=
BOOK_FALLBACKS=18:30,19:00
